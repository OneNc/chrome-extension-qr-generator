{
    "manifest_version": 3,
    "name": "QR Code Generator",
    "version": "1.0.0",
    "description": "Generate QR codes from text or URLs with optional logo",
    "permissions": [
        "storage",
        "tabs"
    ],
    "icons": {
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "QR Code Generator"
    }
}